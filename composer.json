{
    "name": "offscale/cdd-php",
    "version": "0.0.1",
    "description": "Zero-dependency OpenAPI bidirectional compiler for PHP.",
    "type": "library",
    "license": "Apache-2.0",
    "bin": ["bin/cdd-php"],
    "autoload": {
        "files": [
            "src/openapi/parse.php",
            "src/openapi/emit.php"
        ]
    },
    "require": {
        "nikic/php-parser": "^5.7",
        "illuminate/database": "^10.0 || ^11.0",
        "illuminate/routing": "^10.0 || ^11.0",
        "illuminate/events": "^10.0 || ^11.0"
    }
}
